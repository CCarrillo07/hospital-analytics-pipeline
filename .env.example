# ============================================================
# PostgreSQL-specific pipeline connection
# ============================================================
# This section is used by your data pipeline files under src/.
# Keep this section active if your ETL pipeline still runs in PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hospital_management
DB_USER=postgres
DB_PASSWORD=real_password

# ============================================================
# Local LLM
# ============================================================
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# AI Database Assistant connection
# ============================================================
AI_DB_DIALECT=postgresql+psycopg2
AI_DB_DIALECT_NAME=PostgreSQL
AI_DB_HOST=localhost
AI_DB_PORT=5432
AI_DB_NAME=hospital_management
AI_DB_USER=sql_agent
AI_DB_PASSWORD=real_password

# ============================================================
# AI query scope
# ============================================================

AI_DB_SCHEMA=harmonized
AI_DB_ALLOWED_TABLES=patients,doctors,appointments,treatments,billing

# ============================================================
# Optional AI assistant exclusions
# ============================================================

AI_DB_EXCLUDED_SCHEMAS=raw,analytics,automation,information_schema

# ============================================================
# Optional AI assistant domain guidance
# ============================================================
# These values make the assistant reusable.
#
# Keep them blank for a generic database assistant.
# Add values only when you want to provide domain-specific join guidance.
#
# Examples:
#
# Hospital:
 #AI_DB_RELATIONSHIPS=appointments.patient_id = patients.patient_id; appointments.doctor_id = doctors.doctor_id; treatments.appointment_id = appointments.appointment_id; billing.patient_id = patients.patient_id; billing.treatment_id = treatments.treatment_id
 AI_DB_BUSINESS_RULES=When grouping by a descriptive name, also group by the stable identifier when available. Do not join tables unless the question needs columns from more than one table.
#
# Retail:
# AI_DB_RELATIONSHIPS=orders.customer_id = customers.customer_id; order_items.order_id = orders.order_id; order_items.product_id = products.product_id
# AI_DB_BUSINESS_RULES=When ranking customers or products, include the stable identifier when available.
#
# Banking:
# AI_DB_RELATIONSHIPS=transactions.account_id = accounts.account_id; accounts.customer_id = customers.customer_id
# AI_DB_BUSINESS_RULES=When summarizing balances or transactions, include account_id when available.