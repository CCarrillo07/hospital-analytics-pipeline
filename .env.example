# ============================================================
# PostgreSQL-specific pipeline connection
# ============================================================
# This section is used by your data pipeline files under src/.
# Keep this section active if your ETL pipeline still runs in PostgreSQL.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=hospital_management
DB_USER=postgres
DB_PASSWORD=real_password


# ============================================================
# Local LLM
# ============================================================

OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_BASE_URL=http://localhost:11434


# ============================================================
# AI Database Assistant connection
# ============================================================
# IMPORTANT:
# Uncomment only ONE database block at a time.
#
# Supported AI_DB_TYPE values:
# - postgresql
# - oracle
# - sqlserver


# ============================================================
# OPTION 1: PostgreSQL
# ============================================================
# Use this block when the AI assistant should query PostgreSQL.

AI_DB_TYPE=postgresql
AI_DB_DIALECT=postgresql+psycopg2
AI_DB_DIALECT_NAME=PostgreSQL

AI_DB_HOST=localhost
AI_DB_PORT=5432
AI_DB_NAME=hospital_management
AI_DB_USER=sql_agent
AI_DB_PASSWORD=real_password

# SQL Server-only settings.
# Leave these blank for PostgreSQL.
AI_DB_DRIVER=
AI_DB_ENCRYPT=
AI_DB_TRUST_SERVER_CERTIFICATE=

AI_DB_SCHEMA=harmonized
AI_DB_ALLOWED_TABLES=patients,doctors,appointments,treatments,billing


# ============================================================
# OPTION 2: Oracle
# ============================================================
# Use this block when the AI assistant should query Oracle.
#
# To use Oracle:
# 1. Comment out the PostgreSQL block above.
# 2. Uncomment this Oracle block.
# 3. Install the Oracle driver:
#    pip install oracledb
#
# Note:
# AI_DB_NAME is used as the Oracle service name.

# AI_DB_TYPE=oracle
# AI_DB_DIALECT=oracle+oracledb
# AI_DB_DIALECT_NAME=Oracle

# AI_DB_HOST=localhost
# AI_DB_PORT=1521
# AI_DB_NAME=XEPDB1
# AI_DB_USER=sql_agent
# AI_DB_PASSWORD=real_password

# SQL Server-only settings.
# Leave these blank for Oracle.
# AI_DB_DRIVER=
# AI_DB_ENCRYPT=
# AI_DB_TRUST_SERVER_CERTIFICATE=

# Oracle usually stores unquoted schema and table names in uppercase.
# AI_DB_SCHEMA=HARMONIZED
# AI_DB_ALLOWED_TABLES=PATIENTS,DOCTORS,APPOINTMENTS,TREATMENTS,BILLING


# ============================================================
# OPTION 3: Microsoft SQL Server
# ============================================================
# Use this block when the AI assistant should query SQL Server.
#
# To use SQL Server:
# 1. Comment out the PostgreSQL or Oracle block above.
# 2. Uncomment this SQL Server block.
# 3. Install the Python driver:
#    pip install pyodbc
# 4. Install Microsoft ODBC Driver 18 for SQL Server on Windows.

# AI_DB_TYPE=sqlserver
# AI_DB_DIALECT=mssql+pyodbc
# AI_DB_DIALECT_NAME=SQL Server

# AI_DB_HOST=localhost
# AI_DB_PORT=1433
# AI_DB_NAME=hospital_management
# AI_DB_USER=sql_agent
# AI_DB_PASSWORD=real_password

# SQL Server ODBC settings.
# AI_DB_DRIVER=ODBC Driver 18 for SQL Server
# AI_DB_ENCRYPT=no
# AI_DB_TRUST_SERVER_CERTIFICATE=yes

# AI_DB_SCHEMA=harmonized
# AI_DB_ALLOWED_TABLES=patients,doctors,appointments,treatments,billing